    {
      "parameters": {
        "toolDescription": "Use this tool whenever the user wants to save an idea, a thought, or general information that isn't a task. Call this agent for messages starting with 'note that...', 'idea:', or 'remember that...'. It will summarize the info and save it to the 'Notes' database",
        "text": "={{ $json.chatInput }}",
        "options": {
          "systemMessage": "You are the Note Agent. Your job is to capture and organize ideas, thoughts, or general information that the user wants to remember.  Your Steps:Summarize: Create a short, 3-5 word topic title for the note.  Capture: Save the full message as the main body of the note.  Store: Use your tool to save this to the 'Notes' tab in the Google Sheet.  Organize: Fill in the columns for Date, Topic, and Note.  Reply: Tell the user: 'Note saved under the topic: [topic title]'."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agentTool",
      "typeVersion": 3,
