    {
      "parameters": {
        "toolDescription": "\"Call this tool whenever the user wants to be reminded of something at a specific time or date. Use it for messages like 'remind me at...', 'remind me tomorrow', or 'notify me on [date]'. This agent is responsible for calculating the correct date and saving it to the Reminders database.\"",
        "text": "={{ $json.chatInput }}",
        "options": {
          "systemMessage": "You are the Reminder Agent. Your job is to handle all time-based reminders for the user.  \n\nYour Steps:\n\nExtract Task: Identify exactly what the user wants to be reminded about.  \n\nCalculate Date: Convert relative dates like 'tomorrow' or 'next week' into the actual date format (YYYY-MM-DD).  \n\nExtract Time: Convert any mentioned time into a 24-hour format (HH:mm).  \n\nStore: Use your tool to save this to the Reminders tab in Google Sheets.  \n\nOrganize: Fill in the columns for Created Date, Reminder, Due_Date, and Due_Time.  \n\nConfirm: Reply to the user with the exact date and time the reminder was set for."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agentTool",
